{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user in the system.",
      "type": "object",
      "properties": {
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user was created."
        },
        "height": {
          "type": "number",
          "description": "The user's height in cm."
        },
        "weight": {
          "type": "number",
          "description": "The user's weight in kg."
        },
        "bmi": {
          "type": "number",
          "description": "The user's Body Mass Index."
        }
      },
      "required": ["phoneNumber", "createdAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A recipe in the global library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "cuisine": { "type": "string" },
        "prepTime": { "type": "number" },
        "cookTime": { "type": "number" },
        "difficulty": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "ingredients": { "type": "array" },
        "instructions": { "type": "array" },
        "matchReason": { "type": "string" },
        "knowledgeGraph": { "type": "object" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "tags": { "type": "array" },
        "allergens": { "type": "array" }
      },
      "required": ["title", "description", "cuisine", "prepTime", "cookTime", "difficulty", "calories", "protein", "carbs", "fats", "ingredients", "instructions", "matchReason", "knowledgeGraph", "tags"]
    },
    "HistoryRecord": {
      "title": "History Record",
      "description": "A record of user's generated recipes and health advice.",
      "type": "object",
      "properties": {
        "createdAt": { "type": "timestamp" },
        "preferences": { "type": "object" },
        "recipes": { "type": "array" },
        "healthAdvice": { "type": "string" }
      },
      "required": ["createdAt", "preferences", "recipes", "healthAdvice"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles."
    },
    "users/{userId}/history/{historyId}": {
      "schema": {
        "$ref": "#/entities/HistoryRecord"
      },
      "description": "User's generation history."
    },
    "recipes/{recipeId}": {
      "schema": {
        "$ref": "#/entities/Recipe"
      },
      "description": "Global recipe library."
    }
  }
}
