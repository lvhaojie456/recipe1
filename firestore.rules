rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - phoneNumber: string (required)
    //   - createdAt: timestamp (required, immutable)
    //   - height: number (optional, cm)
    //   - weight: number (optional, kg)
    //   - bmi: number (optional)
    //
    // Collection: users/{userId}/history
    // Document ID: {historyId}
    // Fields:
    //   - createdAt: timestamp (required)
    //   - preferences: map (required)
    //   - recipes: list (required)
    //   - healthAdvice: string (required)
    //
    // Collection: recipes
    // Document ID: {recipeId}
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - cuisine: string (required)
    //   - prepTime: number (required)
    //   - cookTime: number (required)
    //   - difficulty: string (required)
    //   - calories: number (required)
    //   - protein: number (required)
    //   - carbs: number (required)
    //   - fats: number (required)
    //   - ingredients: list (required)
    //   - instructions: list (required)
    //   - matchReason: string (required)
    //   - knowledgeGraph: map (required)
    //   - tags: list (required)
    //   - allergens: list (optional)
    //   - authorUid: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['phoneNumber', 'createdAt', 'height', 'weight', 'bmi']) &&
             request.resource.data.phoneNumber is string &&
             request.resource.data.createdAt is timestamp &&
             (!('height' in request.resource.data) || request.resource.data.height is number) &&
             (!('weight' in request.resource.data) || request.resource.data.weight is number) &&
             (!('bmi' in request.resource.data) || request.resource.data.bmi is number);
    }

    function isValidHistoryRecord() {
      return hasRequiredFields(['createdAt', 'preferences', 'recipes', 'healthAdvice']) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.preferences is map &&
             request.resource.data.recipes is list &&
             request.resource.data.healthAdvice is string;
    }

    function isValidRecipe() {
      return hasRequiredFields(['title', 'description', 'cuisine', 'prepTime', 'cookTime', 'difficulty', 'calories', 'protein', 'carbs', 'fats', 'ingredients', 'instructions', 'matchReason', 'knowledgeGraph', 'tags']) &&
             request.resource.data.title is string &&
             request.resource.data.description is string &&
             request.resource.data.cuisine is string &&
             request.resource.data.prepTime is number &&
             request.resource.data.cookTime is number &&
             request.resource.data.difficulty is string &&
             request.resource.data.calories is number &&
             request.resource.data.protein is number &&
             request.resource.data.carbs is number &&
             request.resource.data.fats is number &&
             request.resource.data.ingredients is list &&
             request.resource.data.instructions is list &&
             request.resource.data.matchReason is string &&
             request.resource.data.knowledgeGraph is map &&
             request.resource.data.tags is list &&
             (!('allergens' in request.resource.data) || request.resource.data.allergens is list) &&
             (!('authorUid' in request.resource.data) || request.resource.data.authorUid is string) &&
             (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /users/{userId}/history/{historyId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidHistoryRecord();
      allow update: if isOwner(userId) && isValidHistoryRecord() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }

    match /recipes/{recipeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRecipe();
      allow update: if isAuthenticated() && isValidRecipe();
      allow delete: if isAuthenticated();
    }
  }
}
